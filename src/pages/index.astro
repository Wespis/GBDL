---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-gb-red-deeper via-[#1a0a0a] to-gb-dark py-24 px-4 text-center">
    <!-- Background grid texture -->
    <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(0deg,#fff 0,#fff 1px,transparent 0,transparent 60px),repeating-linear-gradient(90deg,#fff 0,#fff 1px,transparent 0,transparent 60px)"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="inline-block badge bg-gb-red/20 border border-gb-red/40 text-gb-red mb-5">
        Welcome to the League
      </div>
      <h1 class="text-6xl md:text-8xl font-bold text-white mb-2 font-display uppercase tracking-tight leading-none">
        Gridiron
      </h1>
      <h1 class="text-6xl md:text-8xl font-bold text-gb-red mb-5 font-display uppercase tracking-tight leading-none drop-shadow-[0_0_40px_rgba(220,38,38,0.5)]">
        Bloodlines
      </h1>
      <div class="text-gb-gold text-sm md:text-base uppercase tracking-[0.3em] font-medium mb-8">
        Dynasty League &mdash; Season 1
      </div>
      <p class="text-gray-300 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
        A 14-team competitive dynasty fantasy football league. Two conferences. Six playoff spots. One championship ring.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://sleeper.com" target="_blank" rel="noopener" class="btn-primary shadow-lg shadow-red-900/30">
          Open Sleeper App
        </a>
        <a href="https://discord.com" target="_blank" rel="noopener"
           class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors duration-200">
          Join Discord
        </a>
      </div>
    </div>
  </section>

  <!-- Quick stats bar -->
  <section class="bg-gb-red-dark border-y border-gb-red/30">
    <div class="max-w-5xl mx-auto px-4 py-4 grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
      {[
        ['14', 'Teams'],
        ['2',  'Conferences'],
        ['6',  'Playoff Spots'],
        ['$50', 'Annual Dues'],
      ].map(([val, label]) => (
        <div>
          <div class="text-2xl font-bold text-white font-display">{val}</div>
          <div class="text-red-200 text-xs uppercase tracking-wider">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- League Overview Cards -->
  <section class="page-content">
    <h2 class="section-title">
      <span class="text-gb-red">League</span> Overview
    </h2>
    <div class="divider-red"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Structure -->
      <div class="card">
        <div class="text-4xl mb-4">🏈</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">League Structure</h3>
        <ul class="text-gray-300 text-sm space-y-2">
          {[
            '14 teams total',
            'Two 7-team conferences',
            '6 playoff teams advance',
            'Division champions get guaranteed spots',
            'Remaining spots by record & head-to-head',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="text-gb-red mt-0.5 shrink-0">▸</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Financial -->
      <div class="card">
        <div class="text-4xl mb-4">💰</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">League Dues</h3>
        <ul class="text-gray-300 text-sm space-y-2">
          {[
            '$50 per season (subject to member vote)',
            'Payment required before the draft',
            'First season covers two years',
            'Two-year buy-in ensures commitment',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="text-gb-red mt-0.5 shrink-0">▸</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Taxi Squad -->
      <div class="card">
        <div class="text-4xl mb-4">🚕</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Taxi Squad</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Stash developmental talent — especially rookies — before integrating them into your active roster.
          Build your dynasty while competing today.
        </p>
      </div>

      <!-- Brand Building -->
      <div class="card">
        <div class="text-4xl mb-4">🎨</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Brand Building</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Every team creates their own logo and name before the draft. Contact a commissioner for branding assistance.
          Your identity carries across every season.
        </p>
      </div>

      <!-- Championship -->
      <div class="card border-gb-gold/30 hover:border-gb-gold">
        <div class="text-4xl mb-4">🏆</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Bloodline Bowl</h3>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          Champions receive a personalized championship ring. Cash prizes for 2nd and 3rd place.
          Plus Offensive, Defensive, Special Teams, and League MVP awards.
        </p>
        <a href={`${base}bloodline-bowl`} class="text-gb-gold text-sm hover:underline font-medium">Learn more →</a>
      </div>

      <!-- Community -->
      <div class="card">
        <div class="text-4xl mb-4">💬</div>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Community</h3>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          Stay connected via Sleeper for lineup management and Discord for league communication, trash talk, and updates.
        </p>
        <div class="flex gap-2">
          <a href="https://sleeper.com" target="_blank" rel="noopener"
             class="text-xs px-3 py-1.5 bg-green-900/60 hover:bg-green-800 border border-green-800/60 text-green-400 rounded-md transition-colors font-medium">
            Sleeper
          </a>
          <a href="https://discord.com" target="_blank" rel="noopener"
             class="text-xs px-3 py-1.5 bg-indigo-900/60 hover:bg-indigo-800 border border-indigo-800/60 text-indigo-400 rounded-md transition-colors font-medium">
            Discord
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Preseason Checklist -->
  <section class="bg-gb-card border-t border-b border-gb-border py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="section-title"><span class="text-gb-red">Preseason</span> Tasks</h2>
      <div class="divider-red"></div>
      <div class="space-y-4">
        {[
          { num: '01', title: 'Create Your Team Brand', desc: 'Design a team name and logo. Contact a commissioner for assistance. Your brand should reflect your dynasty identity.' },
          { num: '02', title: 'Pay League Dues', desc: '$50 due before the draft. First-season members pay for two years upfront to ensure long-term commitment.' },
          { num: '03', title: 'Join Sleeper & Discord', desc: 'Create accounts on Sleeper (the league platform) and join the league Discord for communication and updates.' },
          { num: '04', title: 'Prepare Your Draft Strategy', desc: 'Study player rankings, dynasty values, and positional needs. Rookie picks are your future — draft wisely.' },
        ].map(task => (
          <div class="flex gap-5 items-start">
            <div class="text-gb-red font-bold text-xl font-display shrink-0 w-8">{task.num}</div>
            <div>
              <div class="text-white font-semibold">{task.title}</div>
              <div class="text-gray-400 text-sm mt-1">{task.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commissioners -->
  <section class="page-content">
    <h2 class="section-title"><span class="text-gb-red">Your</span> Commissioners</h2>
    <div class="divider-red"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {[
        { initials: 'CH', name: 'Chris Hunt', phone: '(210)-823-8224', discord: 'chrish57', email: 'christopherhunt57@gmail.com' },
        { initials: 'WG', name: 'Walker Girard', phone: '(832)-331-2153', discord: 'cybornee', email: 'walkergirard7@gmail.com' },
      ].map(c => (
        <div class="card text-center">
          <div class="w-16 h-16 bg-gb-red rounded-full flex items-center justify-center text-white font-bold text-xl mx-auto mb-4 font-display shadow-lg shadow-red-900/40">
            {c.initials}
          </div>
          <h3 class="text-white font-bold text-xl mb-3">{c.name}</h3>
          <div class="text-gray-400 text-sm space-y-1">
            <div>{c.phone}</div>
            <div>Discord: {c.discord}</div>
            <a href={`mailto:${c.email}`} class="text-gb-gold hover:underline block">{c.email}</a>
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>
