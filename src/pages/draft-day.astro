---
import Layout from '../layouts/Layout.astro';

// Startup draft order — update with actual draft picks as they happen
const draftOrder: string[] = [
  // Add team names in draft order, e.g. 'Team Name (Coach)'
];
---

<Layout title="Draft Day">

  <section class="page-hero">
    <div class="relative max-w-3xl mx-auto">
      <div class="inline-block badge bg-gb-red/20 border border-gb-red/40 text-gb-red mb-4">Season 1</div>
      <h1 class="text-5xl md:text-6xl font-bold text-white font-display uppercase mb-3">Draft Day</h1>
      <p class="text-gray-300 text-lg">The inaugural startup draft that built 14 dynasties.</p>
    </div>
  </section>

  <section class="page-content">

    <!-- Draft Info Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">
      {[
        { icon: '📋', label: 'Draft Type',   value: 'Startup Draft' },
        { icon: '🔄', label: 'Format',       value: 'Snake Draft' },
        { icon: '🏈', label: 'Roster Size',  value: 'Dynasty Roster' },
        { icon: '📅', label: 'Status',       value: 'TBD' },
      ].map(info => (
        <div class="card text-center">
          <div class="text-3xl mb-2">{info.icon}</div>
          <div class="text-gray-400 text-xs uppercase tracking-wider mb-1">{info.label}</div>
          <div class="text-white font-bold font-display text-lg uppercase">{info.value}</div>
        </div>
      ))}
    </div>

    <!-- Draft Format Explainer -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
      <div class="card">
        <h2 class="text-xl font-bold text-white font-display uppercase mb-4">
          <span class="text-gb-red">Startup</span> Draft
        </h2>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          The startup draft is a one-time event where every team builds their entire dynasty roster from scratch.
          All NFL players are available — veterans, rookies, and everything in between.
        </p>
        <p class="text-gray-300 text-sm leading-relaxed">
          After the startup, future drafts will be rookie-only drafts where teams select incoming NFL rookies
          to grow their dynasty over time.
        </p>
      </div>
      <div class="card">
        <h2 class="text-xl font-bold text-white font-display uppercase mb-4">
          <span class="text-gb-red">Taxi</span> Squad
        </h2>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          After the startup draft, coaches can designate select players (especially rookies) to the Taxi Squad.
          These players are stashed for development without counting against your active roster.
        </p>
        <p class="text-gray-300 text-sm leading-relaxed">
          Use the taxi squad to build for the future while fielding a competitive active roster today.
        </p>
      </div>
    </div>

    <!-- Draft Board / Results -->
    <h2 class="text-2xl font-bold text-white font-display uppercase mb-1">
      <span class="text-gb-red">Draft</span> Results
    </h2>
    <div class="h-0.5 w-full bg-gb-border mb-6"></div>

    {draftOrder.length === 0 ? (
      <div class="card text-center py-16">
        <div class="text-5xl mb-4">📋</div>
        <h3 class="text-white font-bold text-xl mb-2 font-display">Draft Results Coming Soon</h3>
        <p class="text-gray-400 text-sm max-w-sm mx-auto">
          The draft results will be posted here after Draft Day. Check back soon!
        </p>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-xl border border-gb-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gb-card-hover text-left">
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">#</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Team</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Pick</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Position</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">NFL Team</th>
            </tr>
          </thead>
          <tbody>
            {draftOrder.map((team, i) => (
              <tr class="border-t border-gb-border hover:bg-gb-card-hover/50 transition-colors">
                <td class="px-4 py-3 text-gb-gold font-bold font-display">{i + 1}</td>
                <td class="px-4 py-3 text-white">{team}</td>
                <td class="px-4 py-3 text-gray-300">—</td>
                <td class="px-4 py-3 text-gray-300">—</td>
                <td class="px-4 py-3 text-gray-300">—</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </section>

</Layout>
