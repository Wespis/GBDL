---
import Layout from '../layouts/Layout.astro';
import draftData from '../data/draft.json';

const picks = draftData.picks;
---

<Layout title="Draft Day">

  <section class="page-hero">
    <div class="relative max-w-3xl mx-auto">
      <div class="inline-block badge bg-gb-red/20 border border-gb-red/40 text-gb-red mb-4">Season 1</div>
      <h1 class="text-5xl md:text-6xl font-bold text-white font-display uppercase mb-3">Draft Day</h1>
      <p class="text-gray-300 text-lg">The inaugural startup draft that built 14 dynasties.</p>
    </div>
  </section>

  <section class="page-content">

    <!-- Draft Info Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">
      {[
        { label: 'Draft Type',  value: 'Startup Draft' },
        { label: 'Format',      value: 'Snake Draft' },
        { label: 'Roster Size', value: 'Dynasty Roster' },
        { label: 'Status',      value: 'TBD' },
      ].map(info => (
        <div class="card text-center">
          <div class="text-gray-400 text-xs uppercase tracking-wider mb-1">{info.label}</div>
          <div class="text-white font-bold font-display text-lg uppercase">{info.value}</div>
        </div>
      ))}
    </div>

    <!-- Draft Format & Taxi Squad -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
      <div class="card">
        <h2 class="text-xl font-bold text-white font-display uppercase mb-4">
          <span class="text-gb-red">Startup</span> Draft
        </h2>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          The startup draft is a one-time event where every team builds their entire dynasty roster from scratch.
          All NFL players are available — veterans, rookies, and everything in between.
        </p>
        <p class="text-gray-300 text-sm leading-relaxed">
          After the startup, future drafts will be rookie-only drafts where teams select incoming NFL rookies
          to grow their dynasty over time.
        </p>
      </div>
      <div class="card">
        <h2 class="text-xl font-bold text-white font-display uppercase mb-4">
          <span class="text-gb-red">Taxi</span> Squad
        </h2>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          After the startup draft, coaches can designate select players (especially rookies) to the Taxi Squad.
          Taxi squad players <strong class="text-white">must be placed before the season's first game</strong> — after
          that window closes, no more placements are allowed.
        </p>
        <p class="text-gray-300 text-sm leading-relaxed">
          Once a player is removed from the taxi squad, they become a <strong class="text-white">permanent bench player</strong> and
          cannot be re-added. Plan your development pipeline carefully.
        </p>
      </div>
    </div>

    <!-- Draft Order Rules -->
    <h2 class="section-title">Draft Order &amp; League Format</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14">
      <div class="card">
        <p class="label mb-3">Year One</p>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Random Order</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          The startup draft order is randomly assigned. Every team enters the inaugural season on equal footing.
        </p>
      </div>
      <div class="card">
        <p class="label mb-3">Subsequent Years</p>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Inverse Finish</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          After year one, rookie draft order follows inverse finishing position. The team that finishes 1st
          picks 12th — rewarding rebuilding teams and preserving competitive balance.
        </p>
      </div>
      <div class="card">
        <p class="label mb-3">Weekly Format</p>
        <h3 class="text-white font-bold text-lg mb-3 font-display uppercase">Two Games Per Week</h3>
        <p class="text-gray-300 text-sm leading-relaxed">
          Every team plays two games each week: one head-to-head matchup and one game against the league
          median score. Beat the median to earn a win — fall below it and take a loss.
        </p>
      </div>
    </div>

    <!-- Draft Board / Results -->
    <h2 class="section-title">Draft Results</h2>

    {picks.length === 0 ? (
      <div class="card text-center py-16">
        <h3 class="text-white font-bold text-xl mb-2 font-display">Draft Results Coming Soon</h3>
        <p class="text-gray-400 text-sm max-w-sm mx-auto">
          The draft results will be posted here after Draft Day. Check back soon!
        </p>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-xl border border-gb-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gb-card-hover text-left">
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">#</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Team</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Player</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">Position</th>
              <th class="px-4 py-3 text-gb-gold font-semibold uppercase text-xs tracking-wider">NFL Team</th>
            </tr>
          </thead>
          <tbody>
            {picks.map((pick: any) => (
              <tr class="border-t border-gb-border hover:bg-gb-card-hover/50 transition-colors">
                <td class="px-4 py-3 text-gb-gold font-bold font-display">{pick.pick}</td>
                <td class="px-4 py-3 text-white font-semibold">{pick.team}</td>
                <td class="px-4 py-3 text-white">{pick.player}</td>
                <td class="px-4 py-3 text-gray-300">{pick.position}</td>
                <td class="px-4 py-3 text-gray-300">{pick.nfl_team}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </section>

</Layout>
