---
import Layout from '../layouts/Layout.astro';
import hofData from '../data/hof.json';

const { inductees, rivalries, records } = hofData as any;
---

<Layout title="Hall of Fame">

  <section class="page-hero">
    <div class="relative max-w-3xl mx-auto">
      <div class="inline-block badge bg-gb-gold/20 border border-gb-gold/40 text-gb-gold mb-4">Legacy</div>
      <h1 class="text-5xl md:text-6xl font-bold text-white font-display uppercase mb-3">Hall of Fame</h1>
      <p class="text-gray-300 text-lg">Records, rivalries, and the legends of Gridiron Bloodlines.</p>
    </div>
  </section>

  <section class="page-content">

    <!-- Records -->
    <h2 class="section-title">League Records</h2>
    <p class="text-gb-muted text-xs -mt-4 mb-8 leading-relaxed">
      All records are reviewed and finalized at the end of each season after the Bloodline Bowl champion is determined.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {records.map((cat: any) => (
        <div class="card">
          <h3 class="text-white font-bold text-lg font-display uppercase mb-4 pb-3 border-b border-gb-border">
            {cat.category}
          </h3>
          <div class="space-y-3">
            {cat.entries.map((rec: any) => (
              <div class="flex justify-between items-start gap-4 py-2 border-b border-gb-border last:border-0">
                <div>
                  <div class="text-gray-300 text-sm">{rec.label}</div>
                  <div class="text-gray-500 text-xs mt-0.5">
                    {rec.holder === '—' ? 'Record holder TBD' : rec.holder}
                  </div>
                </div>
                <div class="text-gb-gold font-bold font-display text-lg shrink-0">{rec.value}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Rivalries -->
    <h2 class="section-title">League Rivalries</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-16">
      {rivalries.map((r: any, i: number) => (
        <div class="card hover:border-gb-gold/30 group">
          <div class="text-gb-gold font-bold text-xs uppercase tracking-widest mb-1 font-display">
            Rivalry #{i + 1}
          </div>
          <h3 class="text-white font-bold text-lg mb-1 font-display uppercase group-hover:text-gb-gold transition-colors">
            {r.name}
          </h3>
          <div class="text-gb-red text-xs font-semibold mb-2 uppercase tracking-wider">{r.teams}</div>
          <p class="text-gray-400 text-sm leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>

    <!-- HOF Inductees -->
    <h2 class="section-title">HOF Inductees</h2>
    {inductees.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {inductees.map((person: any) => (
          <div class="bg-gb-card border border-gb-gold/30 p-6 flex flex-col items-center text-center gap-3">
            {person.photo && (
              <img src={person.photo} alt={person.name} class="w-20 h-20 rounded-full object-cover border-2 border-gb-gold/40" />
            )}
            <div>
              <div class="text-gb-gold text-xs font-bold uppercase tracking-widest mb-1">{person.year} Inductee</div>
              <h3 class="text-white font-bold text-lg font-display uppercase">{person.name}</h3>
              {person.team && <p class="text-gray-400 text-sm">{person.team}</p>}
              {person.note && <p class="text-gray-500 text-xs mt-2 leading-relaxed">{person.note}</p>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="card text-center py-16">
        <h3 class="text-white font-bold text-xl mb-2 font-display">No Inductees Yet</h3>
        <p class="text-gray-400 text-sm max-w-sm mx-auto">
          Hall of Fame inductees will be honored here after seasons of sustained excellence.
          Build your dynasty and leave your legacy.
        </p>
      </div>
    )}

  </section>

</Layout>
