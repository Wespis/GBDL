---
import Layout from '../layouts/Layout.astro';

// Add video IDs here as they are uploaded to YouTube
// e.g. { id: 'dQw4w9WgXcQ', title: '2026 Season Trailer', season: '2026', type: 'trailer' }
type Video = { id: string; title: string; season: string; type: 'trailer' | 'weekly' | 'highlight' | 'other' };
const videos: Video[] = [];
---

<Layout title="GB.tv">

  <section class="page-hero">
    <div class="relative max-w-3xl mx-auto">
      <div class="inline-block badge bg-gb-red/20 border border-gb-red/40 text-gb-red mb-4">Official Media</div>
      <h1 class="text-5xl md:text-6xl font-bold text-white font-display uppercase mb-3">GB.tv</h1>
      <p class="text-gray-300 text-lg">Season trailers, weekly updates, highlights & more.</p>
    </div>
  </section>

  <section class="page-content">

    <!-- Channel info -->
    <div class="flex flex-col md:flex-row gap-8 items-center justify-between bg-gb-card border border-gb-border rounded-2xl p-8 mb-14">
      <div class="flex items-center gap-6">
        <div class="w-20 h-20 bg-gb-red rounded-full flex items-center justify-center text-white font-bold text-2xl font-display shrink-0 shadow-lg shadow-red-900/40">
          GB
        </div>
        <div>
          <div class="text-gray-400 text-xs uppercase tracking-wider mb-1">YouTube Channel</div>
          <h2 class="text-white font-bold text-2xl font-display">@GB.TV_FFL</h2>
          <p class="text-gray-300 text-sm mt-1">
            Weekly updates, season trailers, league highlights, and other fun stuff — all in one place.
          </p>
        </div>
      </div>
      <a
        href="https://youtube.com/@GB.TV_FFL"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary whitespace-nowrap flex items-center gap-2 shrink-0"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
        </svg>
        Subscribe on YouTube
      </a>
    </div>

    <!-- What to expect -->
    <h2 class="section-title"><span class="text-gb-red">What's</span> On GB.tv</h2>
    <div class="divider-red"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-16">
      {[
        { icon: '🎬', title: 'Season Trailers',    desc: 'Epic hype videos to kick off every new season.' },
        { icon: '📰', title: 'Weekly Updates',     desc: "Commissioner breakdowns of each week's action." },
        { icon: '🏆', title: 'Playoff Coverage',   desc: 'Road to the Bloodline Bowl, round by round.' },
        { icon: '🎉', title: 'League Highlights',  desc: 'Best moments, trades, and plays of the year.' },
      ].map(item => (
        <div class="card text-center">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="text-white font-bold font-display uppercase mb-2">{item.title}</h3>
          <p class="text-gray-400 text-sm">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Video Gallery -->
    <h2 class="section-title"><span class="text-gb-red">Latest</span> Videos</h2>
    <div class="divider-red"></div>

    {videos.length === 0 ? (
      <div class="card text-center py-16">
        <div class="text-5xl mb-4">📺</div>
        <h3 class="text-white font-bold text-xl mb-2 font-display">Videos Coming Soon</h3>
        <p class="text-gray-400 text-sm max-w-sm mx-auto mb-6">
          Season trailers and weekly updates will be embedded here as they are published.
        </p>
        <a
          href="https://youtube.com/@GB.TV_FFL"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
          </svg>
          Visit Channel
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map(v => (
          <div class="card p-0 overflow-hidden">
            <div class="aspect-video bg-black">
              <iframe
                src={`https://www.youtube.com/embed/${v.id}`}
                title={v.title}
                class="w-full h-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <div class="p-4">
              <div class="badge bg-gb-red/20 border border-gb-red/30 text-gb-red text-[10px] mb-2">
                {v.season} · {v.type.charAt(0).toUpperCase() + v.type.slice(1)}
              </div>
              <h3 class="text-white font-semibold">{v.title}</h3>
            </div>
          </div>
        ))}
      </div>
    )}

  </section>

</Layout>
