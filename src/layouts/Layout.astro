---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Gridiron Bloodlines Dynasties — 14-team competitive dynasty fantasy football league.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={`${title} | Gridiron Bloodlines`} />
    <meta property="og:description" content={description} />
    <title>{title} | Gridiron Bloodlines</title>
    <!-- Netlify Identity widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="bg-gb-dark text-white min-h-screen flex flex-col font-body antialiased">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Pixel football cursor -->
    <div id="gb-cursor">🏈</div>

    <!-- Redirect to /admin/ after CMS login or invite acceptance -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('login', () => {
          document.location.href = '/admin/';
        });
      }

      // Custom cursor — only on non-touch devices
      if (window.matchMedia('(pointer: fine)').matches) {
        const cursor = document.getElementById('gb-cursor');
        let lastX = 0, lastY = 0, angle = 0;

        document.addEventListener('mousemove', (e) => {
          const x = e.clientX, y = e.clientY;

          // Show on first move
          cursor!.classList.add('active');

          // Rotate football to face direction of travel
          const dx = x - lastX, dy = y - lastY;
          if (Math.abs(dx) > 1 || Math.abs(dy) > 1) {
            angle = Math.atan2(dy, dx) * (180 / Math.PI);
          }
          lastX = x; lastY = y;

          // Position with left/top; transform handles centering + rotation
          cursor!.style.left = x + 'px';
          cursor!.style.top  = y + 'px';
          cursor!.style.transform = `translate(-50%, -50%) rotate(${angle}deg)`;

          // Wind trail particle
          const dot = document.createElement('div');
          dot.className = 'gb-trail';
          dot.style.left = x + 'px';
          dot.style.top  = y + 'px';
          document.body.appendChild(dot);
          setTimeout(() => dot.remove(), 400);
        });
      }
    </script>
  </body>
</html>
