---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: base,                        label: 'Home' },
  { href: `${base}founding-coaches`,   label: 'Coaches' },
  { href: `${base}draft-day`,          label: 'Draft' },
  { href: `${base}season-stats`,       label: 'Stats' },
  { href: `${base}bloodline-bowl`,     label: 'Bowl' },
  { href: `${base}hall-of-fame`,       label: 'HOF' },
  { href: `${base}sponsors`,           label: 'Sponsors' },
  { href: `${base}weekly-updates`,     label: 'Updates' },
  { href: `${base}gb-tv`,             label: 'GB.tv' },
];

function isActive(href: string) {
  if (href === base) return pathname === base || pathname === base.replace(/\/$/, '');
  return pathname.startsWith(href);
}
---

<header class="bg-gb-deeper border-b border-gb-border sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <a href={base} class="flex items-center gap-3 shrink-0">
        <!-- Shield icon -->
        <svg width="26" height="30" viewBox="0 0 28 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 0L28 6V16C28 23.5 22 29.5 14 32C6 29.5 0 23.5 0 16V6L14 0Z" fill="#D50A0A"/>
          <path d="M14 4L24 9V16C24 21.5 19.5 26 14 28C8.5 26 4 21.5 4 16V9L14 4Z" fill="#0D1117"/>
          <text x="14" y="20" font-family="Oswald,sans-serif" font-size="9" font-weight="700"
                fill="white" text-anchor="middle" letter-spacing="0.5">GB</text>
        </svg>
        <div>
          <div class="text-white font-bold text-sm tracking-widest uppercase leading-none"
               style="font-family:'Oswald',sans-serif;">Gridiron Bloodlines</div>
          <div class="text-gb-muted text-[9px] tracking-[0.2em] uppercase">Dynasty League</div>
        </div>
      </a>

      <!-- Desktop Nav: items flush with nav bar, red bottom border on active -->
      <nav class="hidden xl:flex items-stretch h-14">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`flex items-center px-4 text-xs font-bold uppercase tracking-wider border-b-2 transition-colors duration-150 whitespace-nowrap ${
              isActive(link.href)
                ? 'text-white border-gb-red'
                : 'text-gb-muted border-transparent hover:text-white hover:border-gb-red'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile toggle -->
      <button
        id="mobile-menu-btn"
        class="xl:hidden p-2 text-gb-muted hover:text-white transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden xl:hidden bg-gb-deeper border-t border-gb-border">
    <div class="max-w-7xl mx-auto px-4 py-2 grid grid-cols-3 gap-px bg-gb-border">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-4 py-3 text-xs font-bold uppercase tracking-wider transition-colors bg-gb-deeper ${
            isActive(link.href)
              ? 'text-white border-l-2 border-gb-red pl-3'
              : 'text-gb-muted hover:text-white'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  btn?.addEventListener('click', () => {
    const hidden = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!hidden));
    iconOpen?.classList.toggle('hidden', !hidden);
    iconClose?.classList.toggle('hidden', !!hidden);
  });
</script>
