---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-gb-deeper border-t border-gb-border mt-0">
  <!-- Top red accent -->
  <div class="h-1 bg-gb-red"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <svg width="24" height="28" viewBox="0 0 28 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 0L28 6V16C28 23.5 22 29.5 14 32C6 29.5 0 23.5 0 16V6L14 0Z" fill="#D50A0A"/>
            <path d="M14 4L24 9V16C24 21.5 19.5 26 14 28C8.5 26 4 21.5 4 16V9L14 4Z" fill="#0D1117"/>
            <text x="14" y="20" font-family="Oswald,sans-serif" font-size="9" font-weight="700"
                  fill="white" text-anchor="middle" letter-spacing="0.5">GB</text>
          </svg>
          <div>
            <div class="text-white font-bold text-sm uppercase tracking-widest"
                 style="font-family:'Oswald',sans-serif;">Gridiron Bloodlines</div>
            <div class="text-gb-muted text-[9px] tracking-[0.2em] uppercase">Dynasty League</div>
          </div>
        </div>
        <p class="text-gb-muted text-xs leading-relaxed mb-5">
          14-team competitive dynasty fantasy football league. Two conferences. Six playoff spots. One ring.
        </p>
        <div class="flex gap-3">
          <a href="https://sleeper.com/i/m7jkWzwVZPxgg" target="_blank" rel="noopener"
             class="text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 border border-green-800 text-green-600 hover:text-green-400 transition-colors">
            Sleeper
          </a>
          <a href="https://discord.gg/7KMZCfbe" target="_blank" rel="noopener"
             class="text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 border border-[#5865F2]/40 text-[#5865F2] hover:border-[#5865F2] transition-colors">
            Discord
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <div class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-b border-gb-border pb-2">
          League
        </div>
        <ul class="space-y-2.5 text-xs">
          {[
            [base,                       'Home'],
            [`${base}founding-coaches`,  'Founding Coaches'],
            [`${base}draft-day`,         'Draft Day'],
            [`${base}season-stats`,      'Season Stats'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gb-muted hover:text-white transition-colors uppercase tracking-wider font-medium">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <div class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-b border-gb-border pb-2">
          More
        </div>
        <ul class="space-y-2.5 text-xs">
          {[
            [`${base}bloodline-bowl`,   'Bloodline Bowl'],
            [`${base}hall-of-fame`,     'Hall of Fame'],
            [`${base}weekly-updates`,   'Weekly Updates'],
            [`${base}gb-tv`,           'GB.tv'],
            [`${base}sponsors`,         'Sponsors'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gb-muted hover:text-white transition-colors uppercase tracking-wider font-medium">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Commissioners -->
      <div>
        <div class="text-white text-xs font-bold uppercase tracking-widest mb-5 border-b border-gb-border pb-2">
          Commissioners
        </div>
        <div class="space-y-5">
          {[
            { name: 'Chris Hunt',    phone: '(210)-823-8224', discord: 'chrish57',  email: 'christopherhunt57@gmail.com' },
            { name: 'Walker Girard', phone: '(832)-331-2153', discord: 'cybornee', email: 'walkergirard7@gmail.com' },
          ].map(c => (
            <div class="text-xs">
              <div class="text-white font-bold uppercase tracking-wide mb-1">{c.name}</div>
              <div class="text-gb-muted">{c.phone}</div>
              <div class="text-gb-muted">Discord: {c.discord}</div>
              <a href={`mailto:${c.email}`} class="text-gb-red hover:underline">{c.email}</a>
            </div>
          ))}
        </div>
      </div>

    </div>

    <div class="mt-10 pt-6 border-t border-gb-border flex flex-col sm:flex-row items-center justify-between gap-2">
      <span class="text-gb-muted text-xs uppercase tracking-wider">
        &copy; {year} Gridiron Bloodlines Dynasties
      </span>
      <span class="text-gb-border text-xs">Built with Astro &amp; Tailwind CSS</span>
    </div>
  </div>
</footer>
